[
  {
    "PolicyName": "DynamoAccess",
    "PolicyDocument": {
      "Version": "2012-10-17",
      "Statement": [
        {
          "Effect": "Allow",
          "Action": ["dynamodb:GetItem", "dynamodb:PutItem", "dynamodb:Query"],
          "Resource": ["arn:aws:dynamodb:us-east-1:200000000002:table/*"]
        }
      ]
    }
  }
]
