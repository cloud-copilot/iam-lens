{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SharingWithSessionArn",
      "Effect": "Allow",
      "Principal": {
        "AWS": ["arn:aws:sts::200000000002:assumed-role/DynamoDbRole/my-session"]
      },
      "Action": ["s3:ListBucket", "s3:GetObject"],
      "Resource": ["arn:aws:s3:::who-can-session/*", "arn:aws:s3:::who-can-session"]
    }
  ]
}
