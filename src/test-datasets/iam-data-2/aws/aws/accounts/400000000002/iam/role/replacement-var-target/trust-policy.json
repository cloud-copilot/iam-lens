{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "UnusableCondition",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringLike": {
          "aws:PrincipalArn": "${aws:PrincipalTag/team}"
        }
      }
    },
    {
      "Sid": "UsableCondition",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringLike": {
          "aws:PrincipalArn": "arn:aws:iam::400000000001:role/alpha-*"
        }
      }
    }
  ]
}
