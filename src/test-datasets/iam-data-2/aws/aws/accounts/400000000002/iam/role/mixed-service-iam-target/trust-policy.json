{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ServiceAccess",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": { "aws:PrincipalServiceName": "lambda.amazonaws.com" }
      }
    },
    {
      "Sid": "CrossAccountAccess",
      "Effect": "Allow",
      "Principal": { "AWS": "arn:aws:iam::400000000001:root" },
      "Action": "sts:AssumeRole"
    }
  ]
}
