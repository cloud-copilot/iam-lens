[
  {
    "PolicyName": "assume-and-kms",
    "PolicyDocument": {
      "Version": "2012-10-17",
      "Statement": [
        { "Effect": "Allow", "Action": "sts:AssumeRole", "Resource": "*" },
        { "Effect": "Allow", "Action": "kms:Decrypt", "Resource": "*" },
        { "Effect": "Allow", "Action": "s3:GetObject", "Resource": "*" }
      ]
    }
  }
]
